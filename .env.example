# Anthropic API key for Claude
ANTHROPIC_API_KEY=

# Mapbox token for base map tiles (free tier is sufficient)
# Get one at https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Data warehouse location (defaults to ./data/warehouse)
NETSIM_WAREHOUSE_DIR=

# Backend URL (frontend reads NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
